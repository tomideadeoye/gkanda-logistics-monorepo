# =============================================================================
# GK&A Logistics - .gitignore
# Corporate Data Room Repository
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies (DO NOT COMMIT)
# -----------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.venv/
/__pycache__/
/*.egg-info/
/.mypy_cache/

# -----------------------------------------------------------------------------
# Build Outputs (DO NOT COMMIT)
# -----------------------------------------------------------------------------
/.next/
/out/
/build/
/dist/

# -----------------------------------------------------------------------------
# Temporary & Working Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
/temp/
/tmp/
*.tmp
*.temp
*~
*.swp
*.swo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Development Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
coverage/
*.pem
.env*
.vercel
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Database & Local State (DO NOT COMMIT)
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
tasks.db
tasks.json

# -----------------------------------------------------------------------------
# Backup & Duplicate Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
*.bak
*.backup
*_old.*
*_backup.*
*_copy.*

# -----------------------------------------------------------------------------
# Test Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
test_*.py
test_*.js
test_*.html
test_*.pdf

# -----------------------------------------------------------------------------
# Intermediate Conversion Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
*_fixed.*
*_final.*
*_best.*
*_improved.*
*_enhanced.*
*_clean.*
*_complete.*
*_reduced.*
*_manual_edit.*
*_with_*.**/

# -----------------------------------------------------------------------------
# Solution & Debugging Files (DO NOT COMMIT)
# -----------------------------------------------------------------------------
SOLUTION_*.md
FINAL_*.md
WHY_*.md
IMAGE_CENTERING_*.md
USE_*.md
check_*.py
verify_*.py
generate_*.py
convert_*.py
create_*.py
fix_*.py
merge_*.py
optimize_*.py
inspect_*.py
demonstrate_*.py
ensure_*.py
replace_*.py
setup_*.sh
open-*.sh

# -----------------------------------------------------------------------------
# Configuration Files (COMMIT WITH CARE)
# -----------------------------------------------------------------------------
# Keep config files but ignore local overrides
# package-lock.json
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Sensitive Information (NEVER COMMIT)
# -----------------------------------------------------------------------------
# *.key
# *.crt
# *.pfx
# secrets.json
# credentials.*
# password*
# private*

# -----------------------------------------------------------------------------
# Large Binary Files (COMMIT WITH CAUTION)
# -----------------------------------------------------------------------------
# *.zip (unless specifically needed)
# *.exe
# *.dll
# *.so

# -----------------------------------------------------------------------------
# End of .gitignore
# -----------------------------------------------------------------------------
.env*.local
